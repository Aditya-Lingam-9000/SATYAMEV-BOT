# ============================================
# SATYAMEV-BOT ENVIRONMENT CONFIGURATION
# ============================================

# FastAPI Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ENVIRONMENT=development
DEBUG=true

# ============================================
# LLM & AI MODEL APIs
# ============================================

# Groq API (for Llama-3.3-70b & Whisper)
GROQ_API_KEY=your_groq_api_key_here

# Google Generative AI (for Gemini-1.5-Flash)
GOOGLE_API_KEY=your_google_api_key_here

# Tavily Search API (for real-time web consensus)
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# LOCAL CONFIGURATION
# ============================================

# EasyOCR Model Language (comma-separated, e.g., "en,hi")
OCR_LANGUAGES=en

# Maximum file upload size in MB
MAX_UPLOAD_SIZE_MB=50

# Temporary files directory
TEMP_DIR=./temp

# Exports directory for generated cards
EXPORTS_DIR=./exports

# ============================================
# LOGGING
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location
LOG_FILE=./logs/satyamev_bot.log
